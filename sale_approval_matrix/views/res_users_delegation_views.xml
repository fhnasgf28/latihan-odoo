<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_users_delegation_tree" model="ir.ui.view">
        <field name="name">res.users.delegation.tree</field>
        <field name="model">res.users.delegation</field>
        <field name="arch" type="xml">
            <list string="Approver Delegation" decoration-muted="not active">
                <field name="delegator_id"/>
                <field name="delegate_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="reason"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_res_users_delegation_form" model="ir.ui.view">
        <field name="name">res.users.delegation.form</field>
        <field name="model">res.users.delegation</field>
        <field name="arch" type="xml">
            <form string="Approver Delegation">
                <sheet>
                    <group>
                        <group>
                            <field name="delegator_id"/>
                            <field name="delegate_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="active"/>
                            <field name="reason" placeholder="e.g. Annual Leave, Business Trip..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_res_users_delegation" model="ir.actions.act_window">
        <field name="name">Approver Delegations</field>
        <field name="res_model">res.users.delegation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new delegation rule.
            </p>
        </field>
    </record>

    <menuitem id="menu_res_users_delegation"
              name="Approver Delegations"
              parent="sale_approval_matrix.menu_sale_approval_root_config"
              action="action_res_users_delegation"
              sequence="20"/>
</odoo>
