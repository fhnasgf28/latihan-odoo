<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sales_config_settings_form" model="ir.ui.view">
        <field name="name">sales.config.settings.form</field>
        <field name="model">sales.config.settings</field>
        <field name="arch" type="xml">
            <form string="Sales Approval Settings" create="false" delete="false">
                <header>
                    <button name="action_open_settings" string="Open Global Settings" type="object" class="oe_highlight" invisible="id"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group name="general" string="General Rules">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="is_approval_active" widget="boolean_toggle"/>
                            <field name="approval_type"/>
                            <field name="allow_self_approval"/>
                        </group>
                        <group name="constraints" string="Constraints &amp; UI">
                            <field name="lock_so_on_to_approve"/>
                        </group>
                    </group>
                    <group name="notifications" string="Notifications">
                        <field name="notify_via_email"/>
                        <field name="notify_via_chatter"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sales_config_settings" model="ir.actions.act_window">
        <field name="name">Sales Approval Settings</field>
        <field name="res_model">sales.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- Menu Item that triggers a python action to ensure singleton record exists -->
    <record id="action_open_sales_approval_settings_singleton" model="ir.actions.server">
        <field name="name">Sales Approval Settings</field>
        <field name="model_id" ref="model_sales_config_settings"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_settings()
        </field>
    </record>

    <menuitem id="menu_sales_approval_settings"
              name="Sales Approval Settings"
              parent="sale.menu_sale_config"
              action="action_open_sales_approval_settings_singleton"
              sequence="0"/>
</odoo>
