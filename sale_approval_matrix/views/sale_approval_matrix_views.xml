<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Approval Matrix -->
    <record id="view_sale_approval_matrix_tree" model="ir.ui.view">
        <field name="name">sale.approval.matrix.tree</field>
        <field name="model">sale.approval.matrix</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="company_id"/>
                <field name="amount_min"/>
                <field name="amount_max"/>
                <field name="currency_id"/>
                <field name="minimum_approval_count"/>
                <field name="active"/>
                <field name="approver_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_sale_approval_matrix_form" model="ir.ui.view">
        <field name="name">sale.approval.matrix.form</field>
        <field name="model">sale.approval.matrix</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="amount_min"/>
                            <field name="amount_max"/>
                            <field name="currency_id"/>
                            <field name="minimum_approval_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="approver_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Approval Matrix -->
    <record id="action_sale_approval_matrix" model="ir.actions.act_window">
        <field name="name">Sale Approval Matrix</field>
        <field name="res_model">sale.approval.matrix</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Parent Menu for Approval Configuration -->
    <menuitem id="menu_sale_approval_root_config"
              name="Approval Matrix"
              parent="sale.menu_sale_config"
              groups="sales_team.group_sale_manager"
              sequence="100"/>

    <!-- Sub Menu for Matrix Rules -->
    <menuitem id="menu_sale_approval_matrix"
              name="Matrix Rules"
              parent="menu_sale_approval_root_config"
              action="action_sale_approval_matrix"
              sequence="10"/>
</odoo>
