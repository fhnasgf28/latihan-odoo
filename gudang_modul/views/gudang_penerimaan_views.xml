<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════
         VIEWS: gudang.penerimaan
         ══════════════════════════════════════════════════ -->

    <record id="view_gudang_penerimaan_list" model="ir.ui.view">
        <field name="name">gudang.penerimaan.list</field>
        <field name="model">gudang.penerimaan</field>
        <field name="arch" type="xml">
            <list string="Penerimaan Barang" decoration-muted="state == 'cancel'"
                  decoration-success="state == 'done'">
                <field name="nomor"/>
                <field name="tanggal"/>
                <field name="nama_supplier"/>
                <field name="no_surat_jalan"/>
                <field name="lokasi_tujuan_id"/>
                <field name="total_item"/>
                <field name="total_qty"/>
                <field name="total_nilai" widget="monetary" optional="show"/>
                <field name="petugas_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'konfirmasi'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_gudang_penerimaan_form" model="ir.ui.view">
        <field name="name">gudang.penerimaan.form</field>
        <field name="model">gudang.penerimaan</field>
        <field name="arch" type="xml">
            <form string="Penerimaan Barang">
                <header>
                    <!-- Tombol aksi berdasarkan state -->
                    <button name="action_konfirmasi" string="✅ Konfirmasi"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_validasi" string="✔️ Validasi (Selesai)"
                            type="object" class="btn-success"
                            invisible="state != 'konfirmasi'"/>
                    <button name="action_cancel" string="❌ Batalkan"
                            type="object"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_reset_draft" string="↩️ Reset ke Draft"
                            type="object"
                            invisible="state != 'cancel'"/>

                    <!-- Status bar -->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,konfirmasi,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="nomor" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Informasi Penerimaan">
                            <field name="tanggal" readonly="state != 'draft'"/>
                            <field name="nama_supplier" readonly="state != 'draft'"/>
                            <field name="no_surat_jalan" readonly="state != 'draft'"/>
                            <field name="petugas_id" readonly="state != 'draft'"/>
                        </group>
                        <group string="Tujuan">
                            <field name="lokasi_tujuan_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <!-- Tabel Detail Barang -->
                    <field name="line_ids" readonly="state != 'draft'">
                        <list editable="bottom">
                            <field name="produk_id" required="1"/>
                            <field name="satuan" optional="show"/>
                            <field name="stok_sekarang" optional="show" string="Stok Skrg"/>
                            <field name="qty_pesan" optional="show"/>
                            <field name="qty_diterima" required="1"/>
                            <field name="harga_satuan" optional="show" widget="monetary"/>
                            <field name="subtotal" optional="show" widget="monetary"/>
                            <field name="expired_date" optional="hide"/>
                            <field name="keterangan" optional="hide"/>
                        </list>
                    </field>

                    <!-- Totals -->
                    <group class="oe_subtotal_footer">
                        <field name="total_item" readonly="1"/>
                        <field name="total_qty" readonly="1"/>
                        <field name="total_nilai" readonly="1" widget="monetary" class="oe_subtotal_footer_separator"/>
                    </group>

                    <field name="catatan" placeholder="Catatan tambahan..." readonly="state == 'done'"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

