    <record id="action_gudang_penerimaan" model="ir.actions.act_window">
        <field name="name">Penerimaan Barang</field>
        <field name="res_model">gudang.penerimaan</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_gudang_penerimaan_search"/> -->
        <field name="context">{'search_default_done': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Buat dokumen penerimaan barang pertama!
            </p>
        </field>
