    <!-- ACTION -->
    <record id="action_gudang_lot" model="ir.actions.act_window">
        <field name="name">Lot / Batch Produk</field>
        <field name="res_model">gudang.lot</field>
        <field name="view_mode">list,form</field>
        <!-- <field name="search_view_id" ref="view_gudang_lot_search"/> -->
        <field name="context">{'search_default_aktif': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada lot. Lot akan otomatis terbuat saat penerimaan barang.
            </p>
        </field>
