<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gudang_opname_list" model="ir.ui.view">
        <field name="name">gudang.opname.list</field>
        <field name="model">gudang.opname</field>
        <field name="arch" type="xml">
            <list string="Stok Opname" decoration-success="state == 'done'"
                  decoration-muted="state == 'cancel'">
                <field name="nomor"/>
                <field name="tanggal"/>
                <field name="lokasi_id"/>
                <field name="ada_selisih" widget="boolean_toggle" optional="show"/>
                <field name="total_selisih_plus" optional="show"/>
                <field name="total_selisih_minus" optional="show"/>
                <field name="petugas_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_gudang_opname_form" model="ir.ui.view">
        <field name="name">gudang.opname.form</field>
        <field name="model">gudang.opname</field>
        <field name="arch" type="xml">
            <form string="Stok Opname">
                <header>
                    <button name="action_mulai_hitung" string="🔍 Mulai Hitung"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_load_produk" string="📋 Load Semua Produk"
                            type="object"
                            invisible="state not in ('draft', 'progress')"/>
                    <button name="action_validasi" string="✔️ Selesai &amp; Sesuaikan Stok"
                            type="object" class="btn-success"
                            invisible="state != 'progress'"/>
                    <!-- <button name="action_cancel" string="❌ Batalkan"
                            type="object"
                            invisible="state in ('done', 'cancel')"/> -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="nomor" readonly="1"/></h1>
                    </div>

                    <!-- Warning jika ada selisih -->
                    <div class="alert alert-warning" role="alert" invisible="not ada_selisih or state != 'progress'">
                        ⚠️ <strong>Perhatian:</strong> Terdapat selisih stok.
                        Selisih (+): <field name="total_selisih_plus" readonly="1"/> |
                        Selisih (-): <field name="total_selisih_minus" readonly="1"/>
                    </div>

                    <group>
                        <group>
                            <field name="tanggal" readonly="state == 'done'"/>
                            <field name="lokasi_id" readonly="state == 'done'"/>
                            <field name="petugas_id" readonly="state == 'done'"/>
                        </group>
                        <group>
                            <field name="total_selisih_plus" readonly="1"/>
                            <field name="total_selisih_minus" readonly="1"/>
                            <field name="ada_selisih" readonly="1"/>
                        </group>
                    </group>

                    <!-- Tabel opname dengan warna berdasarkan selisih -->
                    <field name="line_ids" readonly="state == 'done'">
                        <list editable="bottom"
                              decoration-danger="status_selisih == 'kurang'"
                              decoration-success="status_selisih == 'lebih'"
                              decoration-muted="status_selisih == 'sesuai'">
                            <field name="produk_id" required="1"/>
                            <field name="satuan" optional="show"/>
                            <field name="qty_sistem" readonly="1" string="Sistem"/>
                            <field name="qty_fisik" string="Fisik (Input)"/>
                            <field name="selisih_qty" readonly="1" string="Selisih"/>
                            <field name="status_selisih" widget="badge"
                                   decoration-danger="status_selisih == 'kurang'"
                                   decoration-success="status_selisih == 'lebih'"
                                   decoration-muted="status_selisih == 'sesuai'"/>
                            <field name="keterangan" optional="show"/>
                        </list>
                    </field>

                    <field name="catatan" placeholder="Catatan opname..." readonly="state == 'done'"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gudang_opname" model="ir.actions.act_window">
        <field name="name">Stok Opname</field>
        <field name="res_model">gudang.opname</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Buat dokumen stok opname pertama!</p>
        </field>
    </record>
</odoo>
