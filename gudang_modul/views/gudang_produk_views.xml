<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════
         VIEWS UNTUK: gudang.produk
         ══════════════════════════════════════════════════ -->

    <!-- LIST VIEW (Tree) -->
    <record id="view_gudang_produk_list" model="ir.ui.view">
        <field name="name">gudang.produk.list</field>
        <field name="model">gudang.produk</field>
        <field name="arch" type="xml">
            <list string="Daftar Produk" decoration-danger="status_stok == 'habis'"
                  decoration-warning="status_stok == 'menipis'"
                  decoration-success="status_stok == 'aman'">
                <field name="kode_produk" optional="show"/>
                <field name="name"/>
                <field name="kategori_id" optional="show"/>
                <field name="satuan"/>
                <field name="stok_tersedia" string="Stok"/>
                <field name="stok_minimum" optional="hide"/>
                <field name="harga_beli" optional="hide" widget="monetary"/>
                <field name="harga_jual" optional="show" widget="monetary"/>
                <field name="status_stok" widget="badge"
                       decoration-danger="status_stok == 'habis'"
                       decoration-warning="status_stok == 'menipis'"
                       decoration-success="status_stok == 'aman'"
                       decoration-info="status_stok == 'berlebih'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_gudang_produk_form" model="ir.ui.view">
        <field name="name">gudang.produk.form</field>
        <field name="model">gudang.produk</field>
        <field name="arch" type="xml">
            <form string="Produk Gudang">
                <!-- Status bar di atas form (untuk status stok) -->
                <header>
                    <field name="status_stok" widget="statusbar"/>
                </header>
                <sheet>
                    <!-- Foto produk di kanan atas -->
                    <field name="gambar" widget="image" class="oe_avatar" options="{'preview_image': 'gambar'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nama Produk..."/></h1>
                        <h2><field name="kode_produk" readonly="1"/></h2>
                    </div>

                    <group>
                        <group string="Informasi Produk">
                            <field name="barcode"/>
                            <field name="kategori_id"/>
                            <field name="satuan"/>
                            <field name="active"/>
                        </group>
                        <group string="Harga">
                            <field name="harga_beli" widget="monetary"/>
                            <field name="harga_jual" widget="monetary"/>
                        </group>
                    </group>

                    <group string="Konfigurasi Stok">
                        <group>
                            <field name="stok_tersedia" readonly="1"/>
                            <field name="stok_minimum"/>
                        </group>
                        <group>
                            <field name="stok_maksimum"/>
                        </group>
                    </group>

                    <field name="deskripsi" placeholder="Deskripsi produk..."/>

                    <!-- Tab untuk riwayat transaksi -->
                    <notebook>
                        <page string="📥 Riwayat Penerimaan">
                            <field name="penerimaan_line_ids" readonly="1">
                                <list>
                                    <field name="penerimaan_id"/>
                                    <field name="tanggal" string="Tanggal"/>
                                    <field name="qty_diterima"/>
                                    <field name="satuan"/>
                                    <field name="harga_satuan" widget="monetary"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="📤 Riwayat Pengeluaran">
                            <field name="pengeluaran_line_ids" readonly="1">
                                <list>
                                    <field name="pengeluaran_id"/>
                                    <field name="tanggal" string="Tanggal"/>
                                    <field name="qty_keluar"/>
                                    <field name="satuan"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter (log aktivitas) -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_gudang_produk_kanban" model="ir.ui.view">
        <field name="name">gudang.produk.kanban</field>
        <field name="model">gudang.produk</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status_stok">
                <field name="name"/>
                <field name="kode_produk"/>
                <field name="stok_tersedia"/>
                <field name="satuan"/>
                <field name="status_stok"/>
                <field name="gambar"/>
                <templates>
                    <t t-name="card">
                        <field name="gambar" widget="image" class="o_kanban_image" style="width:60px;height:60px;"/>
                        <div class="oe_kanban_details">
                            <strong><field name="name"/></strong>
                            <div><field name="kode_produk"/></div>
                            <div>Stok: <field name="stok_tersedia"/> <field name="satuan"/></div>
                            <field name="status_stok" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

