    <!-- ACTION WINDOW -->
    <record id="action_gudang_produk" model="ir.actions.act_window">
        <field name="name">Master Produk</field>
        <field name="res_model">gudang.produk</field>
        <field name="view_mode">list,kanban,form</field>
        <!-- <field name="search_view_id" ref="view_gudang_produk_search"/> -->
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada produk. Tambahkan produk pertama!
            </p>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         VIEWS UNTUK: gudang.kategori.produk
         ══════════════════════════════════════════════════ -->
    <record id="view_gudang_kategori_list" model="ir.ui.view">
        <field name="name">gudang.kategori.produk.list</field>
        <field name="model">gudang.kategori.produk</field>
        <field name="arch" type="xml">
            <list string="Kategori Produk">
                <field name="complete_name"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="view_gudang_kategori_form" model="ir.ui.view">
        <field name="name">gudang.kategori.produk.form</field>
        <field name="model">gudang.kategori.produk</field>
        <field name="arch" type="xml">
            <form string="Kategori Produk">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="complete_name" readonly="1"/>
                    </group>
                    <field name="child_ids">
                        <list>
                            <field name="name"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gudang_kategori" model="ir.actions.act_window">
        <field name="name">Kategori Produk</field>
        <field name="res_model">gudang.kategori.produk</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
