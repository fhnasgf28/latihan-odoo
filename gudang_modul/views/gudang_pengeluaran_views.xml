<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gudang_pengeluaran_list" model="ir.ui.view">
        <field name="name">gudang.pengeluaran.list</field>
        <field name="model">gudang.pengeluaran</field>
        <field name="arch" type="xml">
            <list string="Pengeluaran Barang" decoration-muted="state == 'cancel'"
                  decoration-success="state == 'done'">
                <field name="nomor"/>
                <field name="tanggal"/>
                <field name="tipe_pengeluaran"/>
                <field name="nama_penerima"/>
                <field name="lokasi_asal_id"/>
                <field name="total_item"/>
                <field name="total_qty"/>
                <field name="total_nilai" widget="monetary" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'konfirmasi'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_gudang_pengeluaran_form" model="ir.ui.view">
        <field name="name">gudang.pengeluaran.form</field>
        <field name="model">gudang.pengeluaran</field>
        <field name="arch" type="xml">
            <form string="Pengeluaran Barang">
                <header>
                    <!-- <button name="action_konfirmasi" string="✅ Konfirmasi"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_validasi" string="✔️ Validasi (Selesai)"
                            type="object" class="btn-success"
                            invisible="state != 'konfirmasi'"/>
                    <button name="action_cancel" string="❌ Batalkan"
                            type="object"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_reset_draft" string="↩️ Reset Draft"
                            type="object"
                            invisible="state != 'cancel'"/> -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,konfirmasi,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="nomor" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Informasi Pengeluaran">
                            <field name="tanggal" readonly="state != 'draft'"/>
                            <field name="tipe_pengeluaran" readonly="state != 'draft'"/>
                            <field name="nama_penerima" readonly="state != 'draft'"/>
                            <field name="tujuan" readonly="state != 'draft'"/>
                            <field name="no_dokumen_ref" readonly="state != 'draft'"/>
                            <field name="petugas_id" readonly="state != 'draft'"/>
                        </group>
                        <group string="Asal Barang">
                            <field name="lokasi_asal_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <field name="line_ids" readonly="state != 'draft'">
                        <list editable="bottom">
                            <field name="produk_id" required="1"/>
                            <field name="satuan" optional="show"/>
                            <field name="stok_tersedia" optional="show" string="Stok Tersedia"
                                   decoration-danger="stok_tersedia &lt; qty_keluar"/>
                            <field name="qty_keluar" required="1"/>
                            <field name="harga_satuan" optional="show" widget="monetary"/>
                            <field name="subtotal" optional="show" widget="monetary"/>
                            <field name="keterangan" optional="hide"/>
                        </list>
                    </field>

                    <group class="oe_subtotal_footer">
                        <field name="total_item" readonly="1"/>
                        <field name="total_qty" readonly="1"/>
                        <field name="total_nilai" readonly="1" widget="monetary" class="oe_subtotal_footer_separator"/>
                    </group>

                    <field name="catatan" placeholder="Catatan..." readonly="state == 'done'"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_gudang_pengeluaran" model="ir.actions.act_window">
        <field name="name">Pengeluaran Barang</field>
        <field name="res_model">gudang.pengeluaran</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Buat dokumen pengeluaran barang pertama!</p>
        </field>
    </record>
</odoo>
